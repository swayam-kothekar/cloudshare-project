BACKEND_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
